{
  "name": "StarHub",
  "short_name": "StarHub",
  "description": "Celebrity fan platform for memberships, events, and charitable causes.",
  "start_url": "/index.html",
  "scope": "/",
  "display": "standalone",
  "background_color": "#0a0a14",
