# ─── Django ───────────────────────────────────────────────
SECRET_KEY=django-insecure-multicelebplatform-change-in-production-xyz
DEBUG=True

# ─── Resend SMTP ──────────────────────────────────────────
# 1. Sign up at https://resend.com and add your domain (e.g. yourdomain.com)
# 2. Verify it by adding the DNS records Resend gives you in Cloudflare
# 3. Create an API key at Resend › API Keys
# 4. Fill in the values below
#
# HOST:  smtp.resend.com
# PORT:  465  (SSL — recommended by Resend)
# USER:  resend   ← literal string, not your email
# PASS:  your Resend API key  (starts with re_)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_FBqGSKxR_H3jo1g5XsNeKMwfZdsC7GZcH

# The FROM address — must be a verified domain address in Resend
DEFAULT_FROM_EMAIL=management@celebrity-management.com

# YOUR inbox that receives all payment notifications
# ADMIN_NOTIFICATION_EMAIL=managementofficialwebsite052@gmail.com
ADMIN_NOTIFICATION_EMAIL=management@celebrity-management.com